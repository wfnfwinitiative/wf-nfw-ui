# LLM Service Configuration
# URL for the LLM service that processes voice/audio input
# Example: http://localhost:8000 or https://wf-nfw-llm-services.vercel.app
VITE_LLM_SERVICE_URL=http://localhost:8000

# Backend Service Configuration
# URL for the backend service that manages feature flags, data, etc.
# Example: https://wf-nfw-services-two.vercel.app
VITE_BACKEND_SERVICE_URL=https://wf-nfw-services-two.vercel.app
